# Vite React UI — static build served by a lightweight Node server.

FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY web/package.json web/bun.lock ./
RUN npm install --no-audit --no-fund
COPY web/ ./
RUN npm run build

FROM node:22-bookworm-slim
RUN npm install -g serve && useradd -r -u 10002 -m web
USER web
WORKDIR /home/web
COPY --from=build /app/dist /home/web/dist

ENV PORT=3000
EXPOSE 3000
CMD ["serve", "-s", "dist", "-l", "3000"]
