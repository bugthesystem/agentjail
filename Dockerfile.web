# Next.js admin UI image.

FROM node:22-bookworm-slim AS deps
WORKDIR /app
COPY web/package.json web/package-lock.json ./
RUN npm ci --no-audit --no-fund

FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY web/ ./
RUN npm run build

FROM node:22-bookworm-slim
RUN useradd -r -u 10002 -m web
USER web
WORKDIR /home/web
COPY --from=build /app/.next /home/web/.next
COPY --from=build /app/public /home/web/public
COPY --from=build /app/package.json /home/web/package.json
COPY --from=build /app/node_modules /home/web/node_modules
COPY --from=build /app/next.config.ts /home/web/next.config.ts

ENV PORT=3000
EXPOSE 3000
CMD ["npx", "next", "start", "-p", "3000"]
