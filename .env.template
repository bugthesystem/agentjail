AGENTJAIL_API_KEY=aj_local_<32-hex>
PROXY_BASE_URL=http://server:8443
DATABASE_URL=postgres://agentjail:agentjail@postgres:5432/agentjail

# Persistent workspaces + named snapshots.
# All paths are created on startup if they don't exist.
AGENTJAIL_STATE_DIR=/var/lib/agentjail

# Snapshot retention. Both caps are optional; unset = no limit.
# AGENTJAIL_SNAPSHOT_MAX_AGE_SECS=604800   # 7 days
# AGENTJAIL_SNAPSHOT_MAX_COUNT=200
# AGENTJAIL_SNAPSHOT_GC_TICK_SECS=60

# Content-addressed incremental snapshots. When set, every snapshot
# stores file bodies in this shared pool (SHA-256 addressed) and writes
# a manifest; subsequent snapshots of the same files dedupe. Unset =
# classic full-copy snapshots.
# AGENTJAIL_SNAPSHOT_POOL_DIR=/var/lib/agentjail/snapshot-objects

# Workspace idle-reaper. Scans live workspaces on this interval and
# auto-pauses any with a per-workspace idleTimeoutSecs that has elapsed.
# Default 30s; set to 0 to disable.
# AGENTJAIL_IDLE_CHECK_INTERVAL_SECS=30
