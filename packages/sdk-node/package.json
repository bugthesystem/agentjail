{
  "name": "@agentjail/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for agentjail — open-source phantom-token sandbox control plane.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bugthesystem/agentjail"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "sandbox",
    "ai",
    "agents",
    "phantom-token",
    "openai",
    "anthropic"
  ]
}
